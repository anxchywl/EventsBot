# application settings
LOG_LEVEL=INFO
APP_TIMEZONE=Asia/Almaty

# telegram configuration: BOT_TOKEN (get from @botfather), MINIAPP_BASE_URL (use ngrok url or public https url)
BOT_TOKEN=
TELEGRAM_MINIAPP_SHORT_NAME=events
MINIAPP_BASE_URL=

# admin and moderation: ADMIN_IDS (get telegram id from @userinfobot), MODERATOR_CHAT_ID (get user or group id from @userinfobot)
ADMIN_IDS=
MODERATOR_CHAT_ID=

# app security: SESSION_SECRET (generate with openssl rand -hex 32)
SESSION_SECRET=
MINIAPP_SESSION_TTL_SECONDS=86400
TRUSTED_PROXY_IPS=

# postgresql and redis: POSTGRES_PASSWORD (set strong password for docker)
DATABASE_URL=postgresql+asyncpg://events_bot:events_bot@localhost:54320/events_bot
POSTGRES_PASSWORD=
REDIS_URL=redis://localhost:6379/0

# flutter event submission abuse limits
FLUTTER_EVENT_SUBMIT_RATE_LIMIT=20
FLUTTER_EVENT_SUBMIT_RATE_WINDOW_SECONDS=3600

# smtp email settings: EMAIL_USERNAME (smtp user email), EMAIL_PASSWORD (smtp app password), EMAIL_FROM (sender email address)
EMAIL_HOST=console
EMAIL_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM=
EMAIL_CODE_TTL_MINUTES=10
EMAIL_RESEND_COOLDOWN_SECONDS=60

# media cache limits and ttl
MEDIA_MAX_UPLOAD_BYTES=5000000
MEDIA_COVER_CACHE_TTL=86400
MEDIA_AVATAR_CACHE_TTL=21600

# flutter cover uploads use a private telegram channel the bot administers
# leave blank to disable uploads
# channel ids start with -100
MEDIA_STORAGE_CHAT_ID=
MEDIA_COVER_STAGING_TTL=3600
# legacy telegram bot cover step
BOT_POSTER_UPLOAD_ENABLED=false
