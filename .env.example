# telegram bot token from @botfather
BOT_TOKEN=1234567890:ABCDEFGHIJKLMNOPQRSTUVWXYZ

# application settings
LOG_LEVEL=INFO
APP_TIMEZONE=Asia/Almaty
SESSION_SECRET=replace-with-a-random-production-secret

# database settings
DATABASE_URL=postgresql+asyncpg://events_bot:events_bot@localhost:5432/events_bot
POSTGRES_DB=events_bot
POSTGRES_USER=events_bot
POSTGRES_PASSWORD=replace-with-a-strong-database-password

# redis settings
REDIS_URL=redis://localhost:6379/0
REDIS_DB=0
REDIS_PASSWORD=replace-with-a-strong-redis-password

# public https base url for the telegram mini app
# local browser testing can use http://localhost:8000, but telegram production needs https
MINIAPP_BASE_URL=https://your-domain.example.com
# short name configured in @botfather for direct mini app links
TELEGRAM_MINIAPP_SHORT_NAME=events
MINIAPP_SESSION_TTL_SECONDS=86400
TRUSTED_PROXY_IPS=

# admin and moderation
# list of telegram user ids that are bot administrators (comma separated array or python list format)
ADMIN_IDS=[123456789]
# chat id where the bot should send moderation requests (can be a user id or group id)
MODERATOR_CHAT_ID=123456789

# email settings
EMAIL_HOST=console
EMAIL_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM=
EMAIL_CODE_TTL_MINUTES=10
EMAIL_RESEND_COOLDOWN_SECONDS=60

# media cache settings
MEDIA_MAX_UPLOAD_BYTES=5000000
MEDIA_COVER_CACHE_TTL=86400
MEDIA_AVATAR_CACHE_TTL=21600
