# Telegram Bot Token from @BotFather
BOT_TOKEN=1234567890:ABCDEFGHIJKLMNOPQRSTUVWXYZ

# Application settings
LOG_LEVEL=INFO
APP_TIMEZONE=Asia/Almaty

# Database settings
DATABASE_URL=postgresql+asyncpg://events_bot:events_bot@localhost:5432/events_bot

# Redis settings
REDIS_URL=redis://localhost:6379/0

# Admin and Moderation
# List of Telegram user IDs that are bot administrators (comma separated array or python list format)
ADMIN_IDS=[123456789]
# Chat ID where the bot should send moderation requests (can be a user ID or group ID)
MODERATOR_CHAT_ID=123456789
